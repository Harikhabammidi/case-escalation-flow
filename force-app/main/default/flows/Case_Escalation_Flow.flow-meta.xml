            <targetReference>Notify_Team_via_Chatter</targetReference>
        </connector>
        <inputAssignments>
            <field>OwnerId</field>
            <value>
                <elementReference>Get_Escalation_Queue.Id</elementReference>
            </value>
        </inputAssignments>
